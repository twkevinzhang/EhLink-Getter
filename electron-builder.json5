{
  appId: 'dev.twkevinzhang.ehlinkgetter',
  productName: 'EhLink-Getter',
  directories: {
    output: 'dist/electron',
  },
  files: [
    'out/**/*',
    'package.json',
    {
      from: 'node_modules',
      to: 'node_modules',
      filter: ['**/*'],
    },
  ],
  asar: true,
  asarUnpack: ['resources/sidecar/**', 'out/main/library_import_worker.js'],
  extraResources: [
    {
      from: 'dist/sidecar',
      to: 'sidecar',
      filter: ['**/*'],
    },
    {
      from: 'resources/icon.png',
      to: 'icon.png',
    },
  ],
  win: {
    icon: 'resources/icon.ico',
    target: ['portable'],
  },
  mac: {
    icon: 'resources/icon.icns',
    target: ['dmg', 'zip'],
  },
  publish: [
    {
      provider: 'github',
      owner: 'twkevinzhang',
      repo: 'EhLink-Getter',
    },
  ],
}
