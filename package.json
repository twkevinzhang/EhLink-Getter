{
  "name": "ehlink-getter",
  "version": "0.0.6",
  "description": "EhLink-Getter Desktop App",
  "main": "./out/main/index.js",
  "author": "EhLink-Getter team",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "typecheck:node": "tsc --p tsconfig.node.json --noEmit",
    "typecheck:web": "vue-tsc --p tsconfig.web.json --noEmit",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "build": "electron-vite build",
    "build:sidecar": "cd sidecar && make build",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@primevue/themes": "^4.5.4",
    "@vueuse/core": "^14.1.0",
    "archiver": "^7.0.1",
    "archiver-zip-encryptable": "^1.0.10",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.9.0",
    "combined-stream": "^1.0.8",
    "electron-store": "8.2.0",
    "form-data": "^4.0.5",
    "megajs": "^1.3.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "stream-json": "1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.6.0",
    "@rushstack/eslint-patch": "^1.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^4.5.1",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/tsconfig": "^0.5.0",
    "autoprefixer": "^10.4.23",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-frontmatter": "^0.0.8",
    "eslint-plugin-md": "^1.0.19",
    "eslint-plugin-prettier-vue": "^5.0.0",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^9.1.7",
    "less": "^4.2.0",
    "lint-staged": "^16.4.0",
    "markdown-eslint-parser": "^1.2.1",
    "pinia": "^2.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.0.7",
    "vue": "^3.3.11",
    "vue-tsc": "^3.2.1"
  },
  "packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,less}": [
      "prettier --write"
    ]
  }
}
